<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <title>Login | BlogSphere</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link
    href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:'Poppins', sans-serif;
    }

    body{
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;

      background:
      linear-gradient(
        135deg,
        #0f172a,
        #111827,
        #1e293b
      );

      overflow:hidden;
      position:relative;
    }

    body::before{
      content:"";
      position:absolute;
      width:400px;
      height:400px;
      background:#7c3aed;
      border-radius:50%;
      filter:blur(120px);
      top:-120px;
      left:-100px;
      opacity:0.5;
    }

    body::after{
      content:"";
      position:absolute;
      width:350px;
      height:350px;
      background:#06b6d4;
      border-radius:50%;
      filter:blur(120px);
      bottom:-120px;
      right:-100px;
      opacity:0.4;
    }

    .container{
      width:100%;
      max-width:1100px;

      display:grid;
      grid-template-columns:1fr 1fr;

      background:rgba(255,255,255,0.08);

      border:1px solid rgba(255,255,255,0.1);

      backdrop-filter:blur(20px);

      border-radius:24px;

      overflow:hidden;

      box-shadow:0 25px 50px rgba(0,0,0,0.3);

      position:relative;
      z-index:10;
    }

    .left{
      padding:70px 60px;
      color:white;

      display:flex;
      flex-direction:column;
      justify-content:center;
    }

    .logo{
      font-size:30px;
      font-weight:700;
      margin-bottom:30px;
    }

    .logo span{
      color:#8b5cf6;
    }

    .heading{
      font-size:52px;
      line-height:1.1;
      font-weight:700;
      margin-bottom:24px;
    }

    .description{
      color:#cbd5e1;
      line-height:1.8;
      margin-bottom:40px;
      font-size:16px;
    }

    .features{
      display:flex;
      flex-direction:column;
      gap:18px;
    }

    .feature{
      display:flex;
      align-items:center;
      gap:14px;
      color:#e2e8f0;
    }

    .feature-icon{
      width:42px;
      height:42px;
      border-radius:12px;

      background:rgba(255,255,255,0.08);

      display:flex;
      align-items:center;
      justify-content:center;

      font-size:18px;
    }

    .right{
      background:white;
      padding:60px;

      display:flex;
      flex-direction:column;
      justify-content:center;
    }

    .form-title{
      font-size:38px;
      font-weight:700;
      color:#111827;
      margin-bottom:10px;
    }

    .form-subtitle{
      color:#6b7280;
      margin-bottom:35px;
    }

    .error{
      background:#fee2e2;
      color:#dc2626;
      padding:14px;
      border-radius:12px;
      margin-bottom:20px;
      font-size:14px;
    }

    .input-group{
      margin-bottom:22px;
    }

    .input-group label{
      display:block;
      margin-bottom:8px;
      color:#374151;
      font-size:14px;
      font-weight:500;
    }

    .input-group input{
      width:100%;
      padding:16px;

      border-radius:14px;

      border:1px solid #d1d5db;

      outline:none;

      font-size:15px;

      transition:0.3s;

      background:#f9fafb;
    }

    .input-group input:focus{
      border-color:#8b5cf6;

      box-shadow:
      0 0 0 4px rgba(139,92,246,0.15);

      background:white;
    }

    .login-btn{
      width:100%;

      padding:16px;

      border:none;

      border-radius:14px;

      background:
      linear-gradient(
        135deg,
        #7c3aed,
        #9333ea
      );

      color:white;

      font-size:16px;
      font-weight:600;

      cursor:pointer;

      transition:0.3s;

      margin-top:10px;
    }

    .login-btn:hover{
      transform:translateY(-2px);

      box-shadow:
      0 15px 30px rgba(124,58,237,0.3);
    }

    .bottom-text{
      margin-top:24px;

      text-align:center;

      color:#6b7280;

      font-size:14px;
    }

    .bottom-text a{
      color:#7c3aed;
      text-decoration:none;
      font-weight:600;
    }

    @media(max-width:900px){

      .container{
        grid-template-columns:1fr;
        margin:20px;
      }

      .left{
        display:none;
      }

      .right{
        padding:40px 30px;
      }

      .form-title{
        font-size:30px;
      }

    }

  </style>
</head>

<body>

  <div class="container">

    <div class="left">

      <div class="logo">
        Blog<span>Sphere</span>
      </div>

      <h1 class="heading">
        Welcome Back Writer
      </h1>

      <p class="description">
        Continue your blogging journey, publish amazing
        content, and connect with your readers worldwide.
      </p>

      <div class="features">

        <div class="feature">
          <div class="feature-icon">📝</div>
          <span>Create modern blog articles</span>
        </div>

        <div class="feature">
          <div class="feature-icon">🌎</div>
          <span>Reach readers globally</span>
        </div>

        <div class="feature">
          <div class="feature-icon">🔥</div>
          <span>Build your personal brand</span>
        </div>

      </div>

    </div>

    <div class="right">

      <h2 class="form-title">
        Login
      </h2>

      <p class="form-subtitle">
        Access your account and continue writing.
      </p>

      <% if(error.length > 0){ %>

        <div class="error">
          <%= error %>
        </div>

      <% } %>

      <form action="/login" method="POST">

        <div class="input-group">

          <label>Email Address</label>

          <input
            type="email"
            name="email"
            placeholder="Enter your email"
            required
          />

        </div>

        <div class="input-group">

          <label>Password</label>

          <input
            type="password"
            name="password"
            placeholder="Enter your password"
            required
          />

        </div>

        <button
          type="submit"
          class="login-btn"
        >
          Login Account
        </button>

      </form>

      <div class="bottom-text">

        Don't have an account?

        <a href="/register">
          Register
        </a>

      </div>

    </div>

  </div>

</body>
</html>