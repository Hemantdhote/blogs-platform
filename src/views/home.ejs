<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <title>BlogSphere | Modern Blogging Platform</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">

  <link
    rel="preconnect"
    href="https://fonts.gstatic.com"
    crossorigin
  >

  <link
    href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet"
  />

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:'Poppins', sans-serif;
    }

    body{
      background:#0f172a;
      color:white;
      overflow-x:hidden;
    }

    a{
      text-decoration:none;
      color:inherit;
    }

    .container{
      width:90%;
      max-width:1300px;
      margin:auto;
    }

    /* NAVBAR */

    nav{
      position:fixed;
      width:100%;
      top:0;
      left:0;
      z-index:1000;

      backdrop-filter:blur(15px);

      background:rgba(15,23,42,0.7);

      border-bottom:
      1px solid rgba(255,255,255,0.08);
    }

    .nav-wrapper{
      height:80px;

      display:flex;
      align-items:center;
      justify-content:space-between;
    }

    .logo{
      font-size:30px;
      font-weight:800;
    }

    .logo span{
      color:#8b5cf6;
    }

    .nav-links{
      display:flex;
      align-items:center;
      gap:35px;
    }

    .nav-links a{
      color:#cbd5e1;
      transition:0.3s;
      font-size:15px;
    }

    .nav-links a:hover{
      color:white;
    }

    .nav-buttons{
      display:flex;
      gap:15px;
    }

    .btn{
      padding:12px 22px;
      border-radius:12px;
      font-size:14px;
      font-weight:600;
      transition:0.3s;
    }

    .btn-outline{
      border:1px solid rgba(255,255,255,0.2);
      color:white;
    }

    .btn-outline:hover{
      background:white;
      color:#111827;
    }

    .btn-primary{
      background:
      linear-gradient(
        135deg,
        #7c3aed,
        #9333ea
      );

      color:white;
    }

    .btn-primary:hover{
      transform:translateY(-2px);

      box-shadow:
      0 15px 30px rgba(124,58,237,0.35);
    }

    /* HERO */

    .hero{
      min-height:100vh;

      display:flex;
      align-items:center;

      position:relative;
      overflow:hidden;
    }

    .hero::before{
      content:"";

      position:absolute;

      width:450px;
      height:450px;

      background:#7c3aed;

      border-radius:50%;

      filter:blur(140px);

      top:-120px;
      left:-120px;

      opacity:0.35;
    }

    .hero::after{
      content:"";

      position:absolute;

      width:400px;
      height:400px;

      background:#06b6d4;

      border-radius:50%;

      filter:blur(140px);

      bottom:-120px;
      right:-120px;

      opacity:0.3;
    }

    .hero-content{
      position:relative;
      z-index:10;

      display:grid;
      grid-template-columns:1fr 1fr;
      gap:60px;
      align-items:center;
    }

    .hero-text h1{
      font-size:72px;
      line-height:1.1;
      margin-bottom:25px;
      font-weight:800;
    }

    .hero-text h1 span{
      color:#8b5cf6;
    }

    .hero-text p{
      color:#cbd5e1;
      font-size:18px;
      line-height:1.9;
      margin-bottom:40px;
      max-width:600px;
    }

    .hero-buttons{
      display:flex;
      gap:20px;
    }

    .hero-image{
      position:relative;
    }

    .floating-card{
      background:rgba(255,255,255,0.08);

      border:1px solid rgba(255,255,255,0.1);

      backdrop-filter:blur(20px);

      border-radius:24px;

      padding:30px;

      box-shadow:
      0 25px 50px rgba(0,0,0,0.25);
    }

    .blog-card{
      margin-bottom:20px;
    }

    .blog-tag{
      display:inline-block;

      background:#8b5cf6;

      padding:6px 14px;

      border-radius:30px;

      font-size:12px;

      margin-bottom:15px;
    }

    .blog-title{
      font-size:24px;
      margin-bottom:14px;
      font-weight:700;
    }

    .blog-desc{
      color:#cbd5e1;
      line-height:1.8;
      margin-bottom:20px;
    }

    .blog-author{
      display:flex;
      align-items:center;
      gap:12px;
    }

    .author-avatar{
      width:45px;
      height:45px;
      border-radius:50%;
      background:#7c3aed;
    }

    /* FEATURES */

    .features{
      padding:120px 0;
      background:#111827;
    }

    .section-title{
      text-align:center;
      margin-bottom:70px;
    }

    .section-title h2{
      font-size:48px;
      margin-bottom:18px;
    }

    .section-title p{
      color:#9ca3af;
      max-width:700px;
      margin:auto;
      line-height:1.8;
    }

    .feature-grid{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:30px;
    }

    .feature-card{
      background:#1f2937;
      padding:35px;
      border-radius:24px;
      transition:0.3s;
      border:1px solid transparent;
    }

    .feature-card:hover{
      transform:translateY(-8px);

      border-color:#8b5cf6;
    }

    .feature-icon{
      width:70px;
      height:70px;

      border-radius:18px;

      background:
      linear-gradient(
        135deg,
        #7c3aed,
        #9333ea
      );

      display:flex;
      align-items:center;
      justify-content:center;

      font-size:28px;

      margin-bottom:25px;
    }

    .feature-card h3{
      font-size:24px;
      margin-bottom:15px;
    }

    .feature-card p{
      color:#9ca3af;
      line-height:1.8;
    }

    /* BLOGS */

    .blogs{
      padding:120px 0;
    }

    .blog-grid{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:30px;
    }

    .blog-box{
      background:#111827;
      border-radius:24px;
      overflow:hidden;
      transition:0.3s;
    }

    .blog-box:hover{
      transform:translateY(-10px);
    }

    .blog-image{
      height:220px;

      background:
      linear-gradient(
        135deg,
        #7c3aed,
        #06b6d4
      );
    }

    .blog-content{
      padding:28px;
    }

    .blog-content h3{
      margin-bottom:15px;
      font-size:22px;
    }

    .blog-content p{
      color:#9ca3af;
      line-height:1.8;
      margin-bottom:20px;
    }

    .read-more{
      color:#8b5cf6;
      font-weight:600;
    }

    /* CTA */

    .cta{
      padding:120px 0;
    }

    .cta-box{
      background:
      linear-gradient(
        135deg,
        #7c3aed,
        #4f46e5
      );

      border-radius:32px;

      padding:80px 50px;

      text-align:center;
    }

    .cta-box h2{
      font-size:54px;
      margin-bottom:20px;
    }

    .cta-box p{
      max-width:700px;
      margin:auto;
      line-height:1.8;
      margin-bottom:40px;
      color:#e9d5ff;
    }

    /* FOOTER */

    footer{
      padding:40px 0;
      border-top:
      1px solid rgba(255,255,255,0.08);

      text-align:center;

      color:#9ca3af;
    }

    @media(max-width:1000px){

      .hero-content,
      .feature-grid,
      .blog-grid{
        grid-template-columns:1fr;
      }

      .hero-text h1{
        font-size:52px;
      }

      .nav-links{
        display:none;
      }

      .section-title h2{
        font-size:38px;
      }

      .cta-box h2{
        font-size:40px;
      }

    }

  </style>

</head>

<body>

  <!-- NAVBAR -->

  <nav>

    <div class="container nav-wrapper">

      <div class="logo">
        Blog<span>Sphere</span>
      </div>

      <div class="nav-links">

        <a href="/">Home</a>
        <a href="#">Blogs</a>
        <a href="#">Features</a>
        <a href="#">About</a>

      </div>

      <div class="nav-buttons">

        <a
          href="/login"
          class="btn btn-outline"
        >
          Login
        </a>

        <a
          href="/register"
          class="btn btn-primary"
        >
          Get Started
        </a>

      </div>

    </div>

  </nav>

  <!-- HERO -->

  <section class="hero">

    <div class="container hero-content">

      <div class="hero-text">

        <h1>
          Write Your <span>Ideas</span>
          And Inspire The World
        </h1>

        <p>
          BlogSphere is a modern blogging platform where
          writers, creators, and developers share their
          thoughts, stories, and knowledge with millions
          of readers worldwide.
        </p>

        <div class="hero-buttons">

          <a
            href="/register"
            class="btn btn-primary"
          >
            Start Writing
          </a>

          <a
            href="#blogs"
            class="btn btn-outline"
          >
            Explore Blogs
          </a>

        </div>

      </div>

      <div class="hero-image">

        <div class="floating-card blog-card">

          <span class="blog-tag">
            Technology
          </span>

          <h3 class="blog-title">
            Building Modern Web Applications
          </h3>

          <p class="blog-desc">
            Learn how developers create scalable,
            modern, and beautiful web applications
            using the latest technologies.
          </p>

          <div class="blog-author">

            <div class="author-avatar"></div>

            <div>
              <strong>Hemant Dhote</strong>
              <p>Full Stack Developer</p>
            </div>

          </div>

        </div>

        <div class="floating-card">

          <h3 style="margin-bottom:20px;">
            Platform Stats
          </h3>

          <p style="margin-bottom:12px;">
            ✍️ 15K+ Writers
          </p>

          <p style="margin-bottom:12px;">
            📚 120K+ Articles
          </p>

          <p>
            🌎 Readers from 80+ Countries
          </p>

        </div>

      </div>

    </div>

  </section>

  <!-- FEATURES -->

  <section class="features">

    <div class="container">

      <div class="section-title">

        <h2>
          Why Choose BlogSphere?
        </h2>

        <p>
          Everything you need to build your audience,
          publish content, and grow your online presence.
        </p>

      </div>

      <div class="feature-grid">

        <div class="feature-card">

          <div class="feature-icon">
            ✍️
          </div>

          <h3>
            Easy Writing
          </h3>

          <p>
            Create and publish blogs using a modern
            and distraction-free writing experience.
          </p>

        </div>

        <div class="feature-card">

          <div class="feature-icon">
            🚀
          </div>

          <h3>
            Fast Performance
          </h3>

          <p>
            Optimized platform architecture ensures
            blazing-fast loading and smooth browsing.
          </p>

        </div>

        <div class="feature-card">

          <div class="feature-icon">
            🌎
          </div>

          <h3>
            Global Reach
          </h3>

          <p>
            Connect with readers and creators from
            around the world instantly.
          </p>

        </div>

      </div>

    </div>

  </section>

  <!-- BLOGS -->

  <section
    class="blogs"
    id="blogs"
  >

    <div class="container">

      <div class="section-title">

        <h2>
          Featured Articles
        </h2>

        <p>
          Explore trending stories, tutorials,
          and insights from top creators.
        </p>

      </div>

      <div class="blog-grid">

        <div class="blog-box">

          <div class="blog-image"></div>

          <div class="blog-content">

            <h3>
              Complete MERN Stack Guide
            </h3>

            <p>
              Learn how to build full-stack web apps
              using MongoDB, Express, React, and Node.js.
            </p>

            <a
              href="#"
              class="read-more"
            >
              Read More →
            </a>

          </div>

        </div>

        <div class="blog-box">

          <div class="blog-image"></div>

          <div class="blog-content">

            <h3>
              Master Frontend System Design
            </h3>

            <p>
              Deep dive into scalable frontend
              architecture and UI engineering.
            </p>

            <a
              href="#"
              class="read-more"
            >
              Read More →
            </a>

          </div>

        </div>

        <div class="blog-box">

          <div class="blog-image"></div>

          <div class="blog-content">

            <h3>
              Building Developer Portfolio
            </h3>

            <p>
              Create a stunning portfolio that helps
              you attract recruiters and freelance clients.
            </p>

            <a
              href="#"
              class="read-more"
            >
              Read More →
            </a>

          </div>

        </div>

      </div>

    </div>

  </section>

  <!-- CTA -->

  <section class="cta">

    <div class="container">

      <div class="cta-box">

        <h2>
          Ready To Start Writing?
        </h2>

        <p>
          Join thousands of writers, developers,
          and creators who share their knowledge
          daily on BlogSphere.
        </p>

        <a
          href="/register"
          class="btn btn-outline"
          style="background:white;color:#111827;"
        >
          Create Free Account
        </a>

      </div>

    </div>

  </section>

  <!-- FOOTER -->

  <footer>

    <div class="container">

      <p>
        © 2026 BlogSphere. All Rights Reserved.
      </p>

    </div>

  </footer>

</body>

</html>