<!DOCTYPE html>
<html>
<head>
  <title>Blogs</title>
</head>
<body>

<h1>All Blog Posts</h1>

<% posts.forEach(post => { %>

  <div>

    <h2>
      <a href="/posts/<%= post._id %>">
        <%= post.title %>
      </a>
    </h2>

    <p>
      <%= post.content.substring(0, 100) %>
    </p>

    <p>
      Author:
      <%= post.author.name %>
    </p>

    <p>
      Category:
      <%= post.category %>
    </p>

  </div>

  <hr>

<% }) %>

</body>
</html>